        "#bai 2.11\n",
        "import numpy as np\n",
        "import skfuzzy as fuzz\n",
        "from skfuzzy import control as ctrl\n",
        "rd=ctrl.Antecedent(np.arange(0,51,1),'Ride Distance')\n",
        "tc=ctrl.Antecedent(np.arange(0,101,1),'Traffic Condition')\n",
        "dl=ctrl.Antecedent(np.arange(0,101,1),'Demand Level')\n",
        "wc=ctrl.Antecedent(np.arange(0,11,1),'Weather Condition')\n",
        "cr=ctrl.Antecedent(np.arange(1.0,5.1,0.1),'Customer Rating')\n",
        "rp=ctrl.Antecedent(np.arange(0,101,1),'Ride Punctuality')\n",
        "gia=ctrl.Consequent(np.arange(0,11,0.5),'Price')\n",
        "diem=ctrl.Consequent(np.arange(0,11,1),'Point')\n",
        "\n",
        "rd['short'] = fuzz.trimf(rd.universe, [0,0,3])\n",
        "rd['medium'] = fuzz.trimf(rd.universe, [3,5,8])\n",
        "rd['long'] = fuzz.trimf(rd.universe, [6,13,20])\n",
        "rd['very long'] = fuzz.trimf(rd.universe, [15,50,50])\n",
        "tc['low'] = fuzz.trimf(tc.universe, [0,0,30])\n",
        "tc['medium'] = fuzz.trimf(tc.universe, [20,45,70])\n",
        "tc['high'] = fuzz.trimf(tc.universe, [60,100,100])\n",
        "dl['low'] = fuzz.trimf(dl.universe, [0,0,30])\n",
        "dl['medium'] = fuzz.trimf(dl.universe, [20,45,70])\n",
        "dl['high'] = fuzz.trimf(dl.universe, [60,100,100])\n",
        "wc['bad'] = fuzz.trimf(wc.universe, [0,0,5])\n",
        "wc['moderate'] = fuzz.trimf(wc.universe, [3,5,7])\n",
        "wc['good'] = fuzz.trimf(wc.universe, [6,10,10])\n",
        "cr['poor'] = fuzz.trimf(cr.universe, [1,1,3])\n",
        "cr['average'] = fuzz.trimf(cr.universe, [2,3,4])\n",
        "cr['good'] = fuzz.trimf(cr.universe, [3,5,5])\n",
        "rp['late'] = fuzz.trimf(rp.universe, [0,0,50])\n",
        "rp['on time'] = fuzz.trimf(rp.universe, [40,60,80])\n",
        "rp['early'] = fuzz.trimf(rp.universe, [70,100,100])\n",
        "\n",
        "gia['low'] = fuzz.trimf(gia.universe, [0, 0, 4])\n",
        "gia['medium'] = fuzz.trimf(gia.universe, [3, 5, 7])\n",
        "gia['high'] = fuzz.trimf(gia.universe, [6, 8, 10])\n",
        "gia['very high'] = fuzz.trimf(gia.universe, [8, 10, 10])\n",
        "diem['none'] = fuzz.trimf(diem.universe, [0, 0, 3])\n",
        "diem['few'] = fuzz.trimf(diem.universe, [2, 4, 6])\n",
        "diem['moderate'] = fuzz.trimf(diem.universe, [5, 7, 9])\n",
        "diem['high'] = fuzz.trimf(diem.universe, [8, 10, 10])\n",
        "\n",
        "rule1=ctrl.Rule(rd['short']&tc['low']&dl['low'],gia['low'])\n",
        "rule2=ctrl.Rule(rd['short']&tc['medium']&dl['high'],gia['medium'])\n",
        "rule3=ctrl.Rule(rd['medium']&tc['high']&dl['high'],gia['high'])\n",
        "rule4=ctrl.Rule(rd['long']&tc['medium']&wc['good'],gia['medium'])\n",
        "rule5=ctrl.Rule(rd['long']&tc['high']&wc['bad'],gia['very high'])\n",
        "rule6=ctrl.Rule(rd['very long']&tc['high']&dl['high'],gia['very high'])\n",
        "rule7=ctrl.Rule(rd['medium']&tc['low']&dl['low'],gia['medium'])\n",
        "rule8=ctrl.Rule(rd['short']&tc['high']&wc['bad'],gia['high'])\n",
        "rule9=ctrl.Rule(rd['very long']&wc['bad'],gia['very high'])\n",
        "rule10=ctrl.Rule(rd['medium']&tc['medium']&wc['moderate'],gia['medium'])\n",
        "\n",
        "rule11=ctrl.Rule(cr['good']& rp['early'],diem['high'])\n",
        "rule12=ctrl.Rule(cr['average']&rp['on time'],diem['moderate'])\n",
        "rule13=ctrl.Rule(cr['poor']&rp['late'],diem['none'])\n",
        "rule14=ctrl.Rule(rd['long']&tc['high']&rp['on time'],diem['high'])\n",
        "rule15=ctrl.Rule(rd['medium']&tc['medium']&cr['good'],diem['moderate'])\n",
        "rule16=ctrl.Rule(cr['poor']&rp['late'],diem['none'])\n",
        "rule17=ctrl.Rule(rd['very long']&wc['bad']&cr['good'],diem['high'])\n",
        "rule18=ctrl.Rule(rd['short']&cr['average']&rp['on time'],diem['few'])\n",
        "rule19=ctrl.Rule(rd['long']&tc['high']&rp['late'],diem['few'])\n",
        "rule20=ctrl.Rule(rd['medium']&wc['moderate']&cr['good'],diem['moderate'])\n",
        "grab_ctrl=ctrl.ControlSystem([rule1,rule2,rule3,rule4,rule5,rule6,rule7,rule8,rule9,rule10,rule11,rule12,rule13,rule14,rule15,rule16,rule17,rule18,rule19,rule20])\n",
        "grab=ctrl.ControlSystemSimulation(grab_ctrl)\n",
        "grab.input['Ride Distance']=7\n",
        "grab.input['Traffic Condition']=80\n",
        "grab.input['Demand Level']=90\n",
        "grab.input['Weather Condition']=4\n",
        "grab.input['Customer Rating']=4.5\n",
        "grab.input['Ride Punctuality']=85\n",
        "grab.compute()\n",
        "print(grab.output['Price'])\n",
        "print(grab.output['Point'])\n",
        "gia.view(sim=grab)\n",
        "diem.view(sim=grab)"
