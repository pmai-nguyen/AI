        "#Bai 2.14\n",
        "import numpy as np\n",
        "import skfuzzy as fuzz\n",
        "from skfuzzy import control as ctrl\n",
        "md=ctrl.Antecedent(np.arange(0,201,1),'Mật độ đơn hàng')\n",
        "gh=ctrl.Antecedent(np.arange(0,101,1),'Giao hàng khẩn cấp')\n",
